{
  "name": "@octaspace/sdk-react",
  "version": "0.1.0",
  "description": "React hooks and context for the OctaSpace SDK",
  "keywords": ["octa", "octaspace", "sdk", "react", "hooks", "context"],
  "homepage": "https://github.com/octaspace/js-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/octaspace/js-sdk.git",
    "directory": "packages/sdk-react"
  },
  "license": "MIT",
  "author": "OctaSpace",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "peerDependencies": {
    "@octaspace/sdk": ">=0.1.1",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@octaspace/sdk": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
