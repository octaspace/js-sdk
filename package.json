{
  "name": "octaspace-js-sdk",
  "private": true,
  "description": "OctaSpace JavaScript/TypeScript SDK monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/octaspace/js-sdk.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check packages",
    "lint:fix": "biome check --write packages",
    "format": "biome format --write packages",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
